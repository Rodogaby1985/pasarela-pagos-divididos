{
    "name": "split-payment-gateway",
    "version": "1.0.0",
    "description": "Split Payment Gateway for WooCommerce – frontend build tooling",
    "private": true,
    "scripts": {
        "lint": "vendor/bin/phpcs --standard=phpcs.xml.dist includes/ admin/ split-payment-plugin.php",
        "lint:fix": "vendor/bin/phpcbf --standard=WordPress --extensions=php includes/ admin/ split-payment-plugin.php",
        "build": "webpack --mode production",
        "dev": "webpack --mode development --watch",
        "release": "bash build.sh",
        "release:win": "cmd /c build.bat"
    },
    "devDependencies": {
        "webpack": "^5.88.0",
        "webpack-cli": "^5.1.4",
        "css-loader": "^6.8.1",
        "mini-css-extract-plugin": "^2.7.6",
        "sass": "^1.69.5",
        "sass-loader": "^13.3.2"
    }
}
