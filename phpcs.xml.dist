<?xml version="1.0"?>
<ruleset name="Split Payment Gateway">
	<description>WordPress coding standard for Split Payment Gateway.</description>

	<arg name="extensions" value="php"/>

	<file>includes/</file>
	<file>admin/</file>
	<file>split-payment-plugin.php</file>

	<rule ref="WordPress"/>

	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="manage_woocommerce"/>
			</property>
		</properties>
	</rule>
</ruleset>
