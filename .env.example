# Split Payment Gateway – Environment Variables
# Copy this file to .env and fill in your values (never commit .env to version control).

# ─── Application ──────────────────────────────────────────────────────────────
APP_URL=https://yourstore.example.com
APP_ENV=production              # production | staging | development

# ─── Database ─────────────────────────────────────────────────────────────────
# Normally provided by WordPress (wp-config.php).
# These are only needed for standalone CLI scripts / tests.
DB_HOST=localhost
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=secret

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret

# ─── Nave ─────────────────────────────────────────────────────────────────────
NAVE_API_KEY=nave_live_xxxxxxxxxxxx
NAVE_WEBHOOK_SECRET=your_nave_webhook_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxE
PAYPAL_CLIENT_SECRET=ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxY
PAYPAL_WEBHOOK_ID=xxxxxxxxxxxx
PAYPAL_MODE=live                # live | sandbox

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte key used to encrypt gateway credentials at rest (openssl_random_pseudo_bytes(32) → base64).
SPG_ENCRYPTION_KEY=base64_encoded_32_byte_random_key
